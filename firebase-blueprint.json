{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory item with stock and pricing information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "costPrice", "stockQuantity", "businessId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Record of a transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "priceAtSale": { "type": "number" },
              "costAtSale": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "totalCost": { "type": "number" },
        "profit": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "customerName": { "type": "string" },
        "customerId": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["cash", "credit"] },
        "status": { "type": "string", "enum": ["paid", "pending"] },
        "currency": { "type": "string", "enum": ["USD", "SSP"] },
        "exchangeRate": { "type": "number" },
        "isConfirmed": { "type": "boolean" },
        "amountUSD": { "type": "number" },
        "amountSSP": { "type": "number" },
        "isMixed": { "type": "boolean" }
      },
      "required": ["items", "totalAmount", "totalCost", "profit", "timestamp", "paymentMethod", "businessId", "currency", "status"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "currency": { "type": "string", "enum": ["USD", "SSP"] },
        "exchangeRate": { "type": "number" },
        "amountUSD": { "type": "number" },
        "amountSSP": { "type": "number" },
        "isConfirmed": { "type": "boolean" },
        "employeeId": { "type": "string" }
      },
      "required": ["description", "amount", "timestamp", "businessId", "currency"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information for credit tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "initialBalance": { "type": "number" },
        "initialBalanceCurrency": { "type": "string", "enum": ["USD", "SSP"] }
      },
      "required": ["name", "businessId"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Repayment of credit by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["USD", "SSP"] },
        "creditDeductionUSD": { "type": "number" },
        "amountUSD": { "type": "number" },
        "amountSSP": { "type": "number" },
        "exchangeRate": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "attachmentUrl": { "type": "string" },
        "attachmentType": { "type": "string", "enum": ["image", "pdf"] },
        "isConfirmed": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "transferred"] },
        "transferredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "customerName", "amount", "timestamp", "businessId", "currency", "creditDeductionUSD"]
    },
    "CashTransaction": {
      "title": "CashTransaction",
      "description": "Manual cash in/out entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "type": { "type": "string", "enum": ["in", "out"] },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["USD", "SSP"] },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isConfirmed": { "type": "boolean" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" }
      },
      "required": ["type", "amount", "currency", "notes", "timestamp", "businessId"]
    },
    "Business": {
      "title": "Business",
      "description": "Business profile and settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "logoUrl": { "type": "string" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User specific settings and business association.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "businessId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "businessId"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Employee information and payroll.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "salary": { "type": "number" },
        "salaryCurrency": { "type": "string", "enum": ["USD", "SSP"] },
        "hireDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["name", "position", "salary", "salaryCurrency", "hireDate", "status", "businessId"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Log of stock ins and outs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["sale", "restock", "adjustment", "edit_sale"] },
        "quantity": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "referenceId": { "type": "string" },
        "customerName": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["cash", "credit"] },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["USD", "SSP"] }
      },
      "required": ["productId", "type", "quantity", "timestamp", "businessId"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of inventory products."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales transactions."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of business expenses."
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of registered customers."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Collection of customer repayments."
    },
    "/cashTransactions/{transactionId}": {
      "schema": "CashTransaction",
      "description": "Collection of manual cash transactions."
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Collection of business profiles."
    },
    "/userProfiles/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of business employees."
    },
    "/stockMovements/{movementId}": {
      "schema": "StockMovement",
      "description": "Collection of stock movement logs."
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email.lower() == 'tekle.taf@gmail.com' || 
              request.auth.token.email.lower() == 'awet16@gmail.com');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isBusinessMember(businessId) {
      return isSignedIn() && (
        isAdmin() || (
          exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.businessId == businessId
        )
      );
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'businessId', 'email', 'displayName']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.businessId is string &&
             data.email is string &&
             data.displayName is string;
    }

    function isValidBusiness(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.name is string &&
             data.ownerId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'costPrice', 'stockQuantity', 'businessId']) &&
             data.businessId is string &&
             data.name is string &&
             data.price is number &&
             data.costPrice is number &&
             data.stockQuantity is number;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['items', 'totalAmount', 'totalCost', 'profit', 'timestamp', 'paymentMethod', 'businessId', 'currency', 'status']) &&
             data.businessId is string &&
             data.items is list &&
             data.totalAmount is number &&
             data.timestamp is timestamp &&
             data.paymentMethod in ['cash', 'credit'] &&
             data.status in ['paid', 'pending'];
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'timestamp', 'businessId', 'currency']) &&
             data.businessId is string &&
             data.amount is number &&
             data.timestamp is timestamp;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'businessId']) &&
             data.businessId is string &&
             data.name is string;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['customerId', 'amount', 'timestamp', 'businessId', 'currency', 'creditDeductionUSD']) &&
             data.businessId is string &&
             data.amount is number;
    }

    function isValidCashTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'currency', 'notes', 'timestamp', 'businessId']) &&
             data.businessId is string &&
             data.type in ['in', 'out'] &&
             data.amount is number &&
             data.timestamp is timestamp;
    }

    function isValidStockMovement(data) {
      return data.keys().hasAll(['productId', 'type', 'quantity', 'timestamp', 'businessId']) &&
             data.businessId is string &&
             data.type in ['sale', 'restock', 'adjustment', 'edit_sale'] &&
             data.quantity is number &&
             data.timestamp is timestamp;
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['name', 'position', 'salary', 'salaryCurrency', 'hireDate', 'status', 'businessId']) &&
             data.businessId is string &&
             data.name is string;
    }

    function isValidOrderContainer(data) {
      return data.keys().hasAll(['name', 'status', 'createdAt', 'businessId', 'items', 'totalCost', 'externalExpenses']) &&
             data.businessId is string &&
             data.name is string &&
             data.items is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /userProfiles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && isValidUserProfile(incoming()) && uid == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == uid && isValidUserProfile(incoming());
    }

    match /businesses/{businessId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && isValidBusiness(incoming());
      allow update: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid) && isValidBusiness(incoming());
    }

    match /products/{productId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidProduct(incoming());
      allow update: if isBusinessMember(existing().businessId) && isValidProduct(incoming()) && incoming().businessId == existing().businessId;
      allow delete: if isBusinessMember(existing().businessId);
    }

    match /sales/{saleId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidSale(incoming());
      allow update: if isBusinessMember(existing().businessId) && isValidSale(incoming()) && (isAdmin() || existing().status != 'paid');
      allow delete: if isBusinessMember(existing().businessId) && (isAdmin() || existing().status != 'paid');
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidExpense(incoming());
      allow update: if isBusinessMember(existing().businessId) && isValidExpense(incoming());
      allow delete: if isBusinessMember(existing().businessId);
    }

    match /customers/{customerId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidCustomer(incoming());
      allow update: if isBusinessMember(existing().businessId) && isValidCustomer(incoming());
      allow delete: if isBusinessMember(existing().businessId);
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidPayment(incoming());
      allow update: if isBusinessMember(existing().businessId) && isValidPayment(incoming());
      allow delete: if isBusinessMember(existing().businessId);
    }

    match /cashTransactions/{transactionId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidCashTransaction(incoming());
      allow update: if isBusinessMember(existing().businessId) && isValidCashTransaction(incoming());
      allow delete: if isBusinessMember(existing().businessId);
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidEmployee(incoming());
      allow update: if isBusinessMember(existing().businessId) && isValidEmployee(incoming());
      allow delete: if isBusinessMember(existing().businessId);
    }

    match /stockMovements/{movementId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidStockMovement(incoming());
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /order_containers/{containerId} {
      allow read: if isSignedIn() && (isAdmin() || isBusinessMember(resource.data.businessId));
      allow create: if isBusinessMember(incoming().businessId) && isValidOrderContainer(incoming());
      allow update: if isBusinessMember(existing().businessId) && isValidOrderContainer(incoming());
      allow delete: if isBusinessMember(existing().businessId);
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required, > 0)
    //   - costPrice: number (required, > 0)
    //   - stockQuantity: number (required, >= 0)
    //   - category: string (optional)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: sales
    // Document ID: auto-generated
    // Fields:
    //   - items: list (required)
    //   - totalAmount: number (required, > 0)
    //   - totalCost: number (required, > 0)
    //   - profit: number (required)
    //   - timestamp: timestamp (required)
    //   - customerName: string (optional)
    //
    // Collection: expenses
    // Document ID: auto-generated
    // Fields:
    //   - description: string (required)
    //   - amount: number (required, > 0)
    //   - category: string (optional)
    //   - timestamp: timestamp (required)
    //   - currency: string (required, 'USD' or 'SSP')
    //
    // Collection: cashTransactions
    // Document ID: auto-generated
    // Fields:
    //   - type: string (required, 'in' or 'out')
    //   - amount: number (required, > 0)
    //   - currency: string (required, 'USD' or 'SSP')
    //   - notes: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email.lower() == 'tekle.taf@gmail.com' || 
              request.auth.token.email.lower() == 'awet16@gmail.com') && 
             request.auth.token.email_verified == true;
    }

    function getUserBusinessId() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.businessId
        : null;
    }

    function isBusinessMember(businessId) {
      return isAuthenticated() && (getUserBusinessId() == businessId || isAdmin());
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidEmployee(data) {
      return data.keys().hasAll(['businessId', 'name', 'position', 'salary', 'salaryCurrency', 'hireDate', 'status']) &&
             data.businessId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.position is string && data.position.size() > 0 && data.position.size() < 100 &&
             data.salary is number && data.salary >= 0 &&
             data.salaryCurrency in ['USD', 'SSP'] &&
             data.hireDate is string && data.hireDate.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.status in ['active', 'inactive'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /userProfiles/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /businesses/{businessId} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || getUserBusinessId() == businessId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /products/{id} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow write: if isAuthenticated() && isBusinessMember(request.resource.data.businessId || resource.data.businessId);
    }
    
    match /sales/{id} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow write: if isAuthenticated() && isBusinessMember(request.resource.data.businessId || resource.data.businessId);
    }
    
    match /expenses/{id} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow write: if isAuthenticated() && isBusinessMember(request.resource.data.businessId || resource.data.businessId);
    }
    
    match /customers/{id} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow write: if isAuthenticated() && isBusinessMember(request.resource.data.businessId || resource.data.businessId);
    }
    
    match /payments/{id} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow write: if isAuthenticated() && isBusinessMember(request.resource.data.businessId || resource.data.businessId);
    }
    
    match /cashTransactions/{id} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow write: if isAuthenticated() && isBusinessMember(request.resource.data.businessId || resource.data.businessId);
    }

    match /employees/{id} {
      allow read: if isAuthenticated() && (isAdmin() || (resource.data.businessId != null && getUserBusinessId() == resource.data.businessId));
      allow create: if isAuthenticated() && isValidEmployee(request.resource.data) && (isAdmin() || getUserBusinessId() == request.resource.data.businessId);
      allow update: if isAuthenticated() && isValidEmployee(request.resource.data) && (isAdmin() || (getUserBusinessId() == resource.data.businessId && request.resource.data.businessId == resource.data.businessId));
      allow delete: if isAuthenticated() && (isAdmin() || (resource.data.businessId != null && getUserBusinessId() == resource.data.businessId));
    }
  }
}

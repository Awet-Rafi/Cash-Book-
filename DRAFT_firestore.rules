rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Role-based access using hardcoded emails
    function isAdmin() {
      return isVerified() && 
             (request.auth.token.email.lower() == 'tekle.taf@gmail.com' || 
              request.auth.token.email.lower() == 'awet16@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // O(1) profile lookup (Cached)
    function getUserProfile() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data
        : null;
    }

    function getBusinessId() {
      let profile = getUserProfile();
      return profile != null ? profile.businessId : null;
    }

    function isBusinessMember(businessId) {
      // Swapped order: Admin check first to prevent O(1) profile lookup if possible
      // Actually, Admin check is more expensive than boolean but avoids profile lookup
      return isVerified() && (isAdmin() || (getBusinessId() != null && getBusinessId() == businessId));
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'businessId', 'email', 'displayName']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.businessId is string && data.businessId.size() > 0 && data.businessId.size() <= 128 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidBusiness(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'costPrice', 'stockQuantity', 'businessId']) &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number &&
             data.costPrice is number &&
             data.stockQuantity is number;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['items', 'totalAmount', 'totalCost', 'profit', 'timestamp', 'paymentMethod', 'businessId', 'currency', 'status']) &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.items is list && data.items.size() <= 100 &&
             data.totalAmount is number &&
             data.totalCost is number &&
             data.profit is number &&
             data.timestamp == request.time &&
             data.paymentMethod in ['cash', 'credit'] &&
             data.currency in ['USD', 'SSP'] &&
             data.status in ['paid', 'pending'];
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'timestamp', 'businessId', 'currency']) &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 500 &&
             data.amount is number &&
             data.timestamp == request.time &&
             data.currency in ['USD', 'SSP'];
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'businessId']) &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'amount', 'timestamp', 'businessId', 'currency', 'creditDeductionUSD']) &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.customerId is string && data.customerId.size() <= 128 &&
             data.amount is number &&
             data.timestamp == request.time &&
             data.currency in ['USD', 'SSP'] &&
             data.creditDeductionUSD is number;
    }

    function isValidCashTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'currency', 'notes', 'timestamp', 'businessId']) &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.type in ['in', 'out'] &&
             data.amount is number &&
             data.currency in ['USD', 'SSP'] &&
             data.timestamp == request.time;
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['name', 'position', 'salary', 'salaryCurrency', 'hireDate', 'status', 'businessId']) &&
             data.businessId is string && data.businessId.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.position is string && data.position.size() > 0 && data.position.size() <= 100 &&
             data.salary is number &&
             data.salaryCurrency in ['USD', 'SSP'] &&
             data.status in ['active', 'inactive'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /userProfiles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Allow create for signed in users (even if not verified) to allow onboarding
      allow create: if isSignedIn() && isValidUserProfile(incoming()) && uid == request.auth.uid;
      allow update: if isVerified() && request.auth.uid == uid && 
                     isValidUserProfile(incoming()) && 
                     incoming().businessId == existing().businessId;
    }

    match /businesses/{businessId} {
      allow read: if isVerified() && (resource.data.ownerId == request.auth.uid || isAdmin());
      // Allow create for verified users
      allow create: if isVerified() && isValidBusiness(incoming()) && isValidId(businessId);
      allow update: if isVerified() && (resource.data.ownerId == request.auth.uid || isAdmin()) &&
                     isValidBusiness(incoming()) && 
                     incoming().ownerId == existing().ownerId;
    }

    match /products/{productId} {
      allow read: if isVerified() && (isAdmin() || (resource.data.businessId == getBusinessId()));
      allow create: if isVerified() && isValidProduct(incoming()) && isBusinessMember(incoming().businessId);
      allow update: if isVerified() && isBusinessMember(existing().businessId) && 
                     isValidProduct(incoming()) && 
                     incoming().businessId == existing().businessId;
      allow delete: if isVerified() && isBusinessMember(existing().businessId);
    }

    match /sales/{saleId} {
      allow read: if isVerified() && (isAdmin() || (resource.data.businessId == getBusinessId()));
      allow create: if isVerified() && isValidSale(incoming()) && isBusinessMember(incoming().businessId);
      allow update: if isVerified() && isBusinessMember(existing().businessId) &&
                     isValidSale(incoming()) &&
                     incoming().businessId == existing().businessId &&
                     (isAdmin() || (existing().status != 'paid'));
      allow delete: if isVerified() && isBusinessMember(existing().businessId) && (isAdmin() || existing().status != 'paid');
    }

    match /expenses/{expenseId} {
      allow read: if isVerified() && (isAdmin() || (resource.data.businessId == getBusinessId()));
      allow create: if isVerified() && isValidExpense(incoming()) && isBusinessMember(incoming().businessId);
      allow update: if isVerified() && isBusinessMember(existing().businessId) &&
                     isValidExpense(incoming()) &&
                     incoming().businessId == existing().businessId;
      allow delete: if isVerified() && isBusinessMember(existing().businessId);
    }

    match /customers/{customerId} {
      allow read: if isVerified() && (isAdmin() || (resource.data.businessId == getBusinessId()));
      allow create: if isVerified() && isValidCustomer(incoming()) && isBusinessMember(incoming().businessId);
      allow update: if isVerified() && isBusinessMember(existing().businessId) &&
                     isValidCustomer(incoming()) &&
                     incoming().businessId == existing().businessId;
      allow delete: if isVerified() && isBusinessMember(existing().businessId);
    }

    match /payments/{paymentId} {
      allow read: if isVerified() && (isAdmin() || (resource.data.businessId == getBusinessId()));
      allow create: if isVerified() && isValidPayment(incoming()) && isBusinessMember(incoming().businessId);
      allow update: if isVerified() && isBusinessMember(existing().businessId) &&
                     isValidPayment(incoming()) &&
                     incoming().businessId == existing().businessId;
      allow delete: if isVerified() && isBusinessMember(existing().businessId);
    }

    match /cashTransactions/{transactionId} {
      allow read: if isVerified() && (isAdmin() || (resource.data.businessId == getBusinessId()));
      allow create: if isVerified() && isValidCashTransaction(incoming()) && isBusinessMember(incoming().businessId);
      allow update: if isVerified() && isBusinessMember(existing().businessId) &&
                     isValidCashTransaction(incoming()) &&
                     incoming().businessId == existing().businessId;
      allow delete: if isVerified() && isBusinessMember(existing().businessId);
    }

    match /employees/{employeeId} {
      allow read: if isVerified() && (isAdmin() || (resource.data.businessId == getBusinessId()));
      allow create: if isVerified() && isValidEmployee(incoming()) && isBusinessMember(incoming().businessId);
      allow update: if isVerified() && isBusinessMember(existing().businessId) &&
                     isValidEmployee(incoming()) &&
                     incoming().businessId == existing().businessId;
      allow delete: if isVerified() && isBusinessMember(existing().businessId);
    }
  }
}
